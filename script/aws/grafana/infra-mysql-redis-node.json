    "h": 1,
    "w": 24,
    "x": 0,
    "y": 0
   },
   "panels": []
  },
  {
   "id": 2,
   "type": "timeseries",
   "title": "InnoDB row lock time (ms/s)",
   "description": "V2 부하 중 치솟고 V3는 0에 가까우면 락 보유 시간 서사 입증",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROM}"
   },
   "gridPos": {
    "h": 8,
    "w": 8,
    "x": 0,
    "y": 1
   },
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineWidth": 2,
      "fillOpacity": 12,
      "showPoints": "never",
      "spanNulls": true
     },
     "unit": "ms"
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROM}"
     },
     "expr": "rate(mysql_global_status_innodb_row_lock_time[$__rate_interval])",
     "legendFormat": "lock time ms/s",
     "refId": "A"
    }
   ]
  },
  {
   "id": 3,
   "type": "timeseries",
   "title": "Row lock waits",
