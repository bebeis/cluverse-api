 "schemaVersion": 39,
 "version": 1,
 "refresh": "10s",
 "time": {
  "from": "now-15m",
  "to": "now"
 },
 "templating": {
  "list": [
   {
    "name": "DS_PROM",
    "label": "datasource",
    "type": "datasource",
    "query": "prometheus",
    "current": {},
    "hide": 0,
    "refresh": 1,
    "options": [],
    "regex": ""
   }
  ]
 },
 "editable": true,
